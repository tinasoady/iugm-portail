generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Rôles officiels basés sur le diagramme de cas d'utilisation
enum Role {
  SUPERADMIN
  AGENT_ADMINISTRATION
  AGENT_PEDAGOGIQUE
  ETUDIANT
}

// Table centrale pour la gestion de l'authentification et des profils
model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  // Force le changement de mot de passe à la prochaine connexion
  // (vrai pour les comptes étudiants créés avec le matricule comme mot de passe)
  mustChangePassword Boolean @default(false)
  // Compte désactivé : connexion refusée (géré depuis la page Permissions)
  active Boolean @default(true)
  // Fonction / poste (ex : Secrétaire, Chef de scolarité, Responsable finance...)
  jobTitle String?
  // Photo de profil (data URL, gérée par l'utilisateur sur sa page Mon compte)
  photo String?
  // Tâches autorisées pour cet utilisateur (clés du catalogue lib/permissions.ts).
  // Deux agents du même rôle peuvent avoir des permissions différentes.
  permissions String[] @default([])
  // Formation affectée (ex : "Management") : l'agent ne voit et ne manipule
  // que les dossiers de cette formation. Null = toutes les formations.
  formation String?
  role         Role       @default(ETUDIANT)
  fullName     String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  auditLogs    AuditLog[]
  // Dossier étudiant lié si ce compte a été créé via la validation pédagogique
  studentFile  Student?
  // Communiqués rédigés (agents) et marques de lecture (étudiants)
  announcements     Announcement[]     @relation("AuthoredAnnouncements")
  announcementReads AnnouncementRead[]
}

// Workflow d'inscription d'un étudiant
enum StudentStatus {
  ENREGISTRE // dossier créé par l'agent d'administration
  PAIEMENT_VERIFIE // reçu bancaire vérifié
  ADMIN_VALIDEE // inscription administrative validée
  INSCRIT // inscription pédagogique validée, compte étudiant créé
}

// Dossier étudiant géré par les agents (distinct du compte de connexion User)
model Student {
  id           String  @id @default(cuid())
  matricule    String  @unique // format FI2026-1 (FI + année d'inscription + n° séquentiel)
  academicYear String? // année universitaire de rattachement, ex "2026-2027"

  // Identité
  fullName      String // "NOM Prénom" (affichage et compatibilité)
  lastName      String?
  firstName     String?
  gender        String? // "M" | "F"
  birthDate     DateTime?
  birthPlace    String?
  motherName    String?
  fatherName    String?
  nationality   String? // "Malagasy" | "Étranger"
  maritalStatus String? // situation familiale : Célibataire | Marié(e) | Salarié(e)

  // Carte d'identité nationale
  cin           String?
  cinIssueDate  DateTime?
  cinIssuePlace String?

  // Renseignements sur le baccalauréat
  baccNumber         String? // numéro du bacc
  baccYear           String? // année d'obtention
  baccSeries         String? // série
  baccMention        String? // mention obtenue au bacc
  baccCenter         String? // centre d'examen
  baccCountry        String? // pays
  previousSchool     String? // établissement d'origine
  previousUniversity String? // inscription antérieure à l'université
  repeatCode         String? // hérité : N = nouveau, R = redoublant, T = triplant

  // Contact
  address       String? // adresse exacte de l'étudiant
  phone         String?
  personalEmail String?

  // Parents
  parentsPhone   String?
  parentsAddress String?
  parentsCity    String?

  // Personne à contacter d'urgence (obligatoire pour chaque étudiant)
  guardianName    String?
  guardianPhone   String?
  guardianAddress String?

  // Pièces du dossier (cochées par l'agent à la réception)
  docResidenceCert    Boolean @default(false) // certificat de résidence
  docCinCopy          Boolean @default(false) // copie légalisée CIN / acte d'état civil (mineur)
  docParentCin        Boolean @default(false) // CIN légalisée du parent
  docPhotos           Boolean @default(false) // 4 photos d'identité récentes
  docPinkFolder       Boolean @default(false) // papier chemise rose
  docPaymentSlip      Boolean @default(false) // bordereau de versement
  docEngagementLetter Boolean @default(false) // lettre d'engagement co-signée

  // Cursus
  domain       String? // domaine
  mention      String? // mention du cursus
  track        String? // parcours
  trainingType String? // type de formation
  program      String? // hérité : filière (alimenté avec la mention)
  level        String? // hérité : niveau
  department   String? // hérité : département (alimenté avec le domaine)

  receiptNumber String? // numéro du reçu bancaire vérifié
  conduct       String? // appréciation de conduite (rédigée par l'agent pédagogique)
  status        StudentStatus @default(ENREGISTRE)
  // Horodatages dédiés (au lieu de retrouver la date dans le journal d'audit,
  // qui n'est pas lié au dossier et survit à sa suppression) : le graphique du
  // tableau de bord doit refléter seulement les dossiers qui existent encore.
  receiptVerifiedAt  DateTime?
  pedagoValidatedAt  DateTime?
  // Compte de connexion créé automatiquement à la validation pédagogique
  account         User?   @relation(fields: [accountId], references: [id], onDelete: SetNull)
  accountId       String? @unique
  // Mot de passe initial du compte, imprimé sur le reçu d'inscription pour être
  // remis à l'étudiant (à changer par l'étudiant à sa première connexion)
  initialPassword String?
  // Années universitaires précédentes (archivées à chaque réinscription)
  enrollmentHistory EnrollmentHistory[]
  results       AcademicResult[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([fullName])
  @@index([status])
  @@index([academicYear])
  // + index trigram (pg_trgm/GIN) sur fullName, matricule, receiptNumber,
  // program, department, cin, track pour les recherches "contains" — voir la
  // migration 20260721153910_student_search_trgm_index (SQL brut : la syntaxe
  // Prisma ne modélise pas l'opclass gin_trgm_ops).
}

// Année universitaire passée d'un étudiant, archivée lors de sa réinscription
model EnrollmentHistory {
  id            String   @id @default(cuid())
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId     String
  academicYear  String
  track         String? // parcours / classe suivie cette année-là
  status        String // statut au moment de l'archivage (normalement INSCRIT)
  receiptNumber String?
  archivedAt    DateTime @default(now())

  @@index([studentId])
}

// Mention calculée automatiquement à partir de la moyenne (/20)
enum Mention {
  ECHEC // < 10
  PASSABLE // 10 à < 12
  ASSEZ_BIEN // 12 à < 14
  BIEN // 14 à < 16
  TRES_BIEN // >= 16
}

// Résultat académique assigné par l'agent pédagogique
model AcademicResult {
  id           String   @id @default(cuid())
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId    String
  academicYear String // ex: "2025-2026"
  semester     String // "S1", "S2"...
  average      Float // moyenne sur 20
  mention      Mention
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([studentId, academicYear, semester])
  @@index([mention])
}

// Communiqué envoyé par un agent aux étudiants (lecture seule côté étudiant).
// Ciblage par groupe : filière et/ou niveau ; null = tous.
model Announcement {
  id        String             @id @default(cuid())
  title     String
  body      String
  formation String? // filière ciblée (null = toutes)
  level     String? // niveau ciblé (null = tous)
  author    User?              @relation("AuthoredAnnouncements", fields: [authorId], references: [id], onDelete: SetNull)
  authorId  String?
  reads     AnnouncementRead[]
  createdAt DateTime           @default(now())

  @@index([createdAt])
}

// Marque de lecture d'un communiqué par un étudiant (badge « non lu »)
model AnnouncementRead {
  id             String       @id @default(cuid())
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  announcementId String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  readAt         DateTime     @default(now())

  @@unique([announcementId, userId])
}

// Paramètres de l'établissement (clé/valeur) : nom, adresse, logo (data URL), etc.
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// Tarifs configurables par le superadmin (droits d'inscription, scolarité...)
model Tariff {
  id        String   @id @default(cuid())
  label     String
  amount    Int // montant en ariary
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Journal des actions sensibles (connexions, créations de comptes, etc.)
model AuditLog {
  id        String   @id @default(cuid())
  action    String // ex: LOGIN_SUCCESS, LOGIN_FAILED, USER_CREATED
  details   String? // contexte lisible (email ciblé, rôle attribué, etc.)
  // L'acteur est optionnel : un LOGIN_FAILED n'a pas d'utilisateur identifié
  actor     User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  actorId   String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// Tentatives de connexion (succès et échecs), utilisées uniquement pour le
// blocage anti-bruteforce. Distinct de AuditLog (texte libre, lecture humaine) :
// ici les colonnes sont indexées pour compter rapidement les échecs récents
// par email et par IP.
model LoginAttempt {
  id        String   @id @default(cuid())
  email     String
  ip        String?
  success   Boolean
  createdAt DateTime @default(now())

  @@index([email, createdAt])
  @@index([ip, createdAt])
}