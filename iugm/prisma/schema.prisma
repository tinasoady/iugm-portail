generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Rôles officiels basés sur le diagramme de cas d'utilisation
enum Role {
  SUPERADMIN
  AGENT_ADMINISTRATION
  AGENT_PEDAGOGIQUE
  ETUDIANT
}

// Table centrale pour la gestion de l'authentification et des profils
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(ETUDIANT)
  fullName     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}